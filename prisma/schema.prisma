// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Login {
  id          String       @id @default(cuid())
  email       String       @unique
  password    String
  role        String       @default("STAFF")
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  logins      Login[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bills     Bill[]
}

model Product {
  id        String     @id @default(cuid())
  name      String
  brand     String?
  price     Float
  stock     Int
  category  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  billItems BillItem[]
}

model Bill {
  id            String     @id @default(cuid())
  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id])
  items         BillItem[]
  totalAmount   Float
  paymentMethod String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model BillItem {
  id        String  @id @default(cuid())
  billId    String
  bill      Bill    @relation(fields: [billId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Payment {
  id        String   @id @default(cuid())
  billId    String
  amount    Float
  method    String
  createdAt DateTime @default(now())
}

model Supplier {
  id    String @id @default(cuid())
  name  String
  phone String
}

model Purchase {
  id         String @id @default(cuid())
  supplierId String
  total      Float
}

model StockHistory {
  id        String @id @default(cuid())
  productId String
  change    Int
  type      String // IN / OUT
}
